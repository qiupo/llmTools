{
  "manifest_version": 3,
  "name": "llmTools",
  "description": "Translate the current webpage with the local llmTools app.",
  "version": "0.2.0",
  "key": "",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "nativeMessaging",
    "contextMenus"
  ],
  "optional_host_permissions": [
    "http://*/*",
    "https://*/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "llmTools"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+L",
        "mac": "Alt+Shift+L"
      },
      "description": "Open llmTools"
    }
  }
}
